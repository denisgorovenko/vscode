{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "moduleResolution": "node",
    "baseUrl": ".", 
    "paths": {
      "@pages/*": ["pages/*"],
      "@common/*": ["common/*"]
    },
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["tests/**/*.ts", "pages/**/*.ts", "common/**/*.ts", "blocks/**/*.ts"]
}